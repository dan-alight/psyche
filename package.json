{
  "name": "psyche",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @psyche/api dev\" \"pnpm --filter @psyche/web dev\"",
    "dev:api": "pnpm --filter @psyche/api dev",
    "dev:web": "pnpm --filter @psyche/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @psyche/api db:generate",
    "db:migrate": "pnpm --filter @psyche/api db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.11.0"
}
